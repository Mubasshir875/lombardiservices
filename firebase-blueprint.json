{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user account details and balance.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "balance": { "type": "number" },
        "totalSpent": { "type": "number" },
        "createdAt": { "type": "object", "description": "Firestore Timestamp" }
      },
      "required": ["uid", "email", "role", "balance"]
    },
    "Service": {
      "title": "SMM Service",
      "description": "Available SMM services for purchase.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "rate": { "type": "string" },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["name", "rate", "min", "max"]
    },
    "Order": {
      "title": "Service Order",
      "description": "Orders placed by users.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "serviceId": { "type": "string" },
        "serviceName": { "type": "string" },
        "link": { "type": "string" },
        "quantity": { "type": "number" },
        "charge": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "In Progress", "Completed", "Cancelled"] },
        "createdAt": { "type": "object" }
      },
      "required": ["uid", "serviceId", "quantity", "charge", "status"]
    },
    "Ticket": {
      "title": "Support Ticket",
      "description": "Support requests from users.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["Open", "Closed"] },
        "createdAt": { "type": "object" }
      },
      "required": ["uid", "subject", "message", "status"]
    },
    "Transaction": {
      "title": "Financial Transaction",
      "description": "Records of deposits and payments.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string", "enum": ["paypal", "crypto"] },
        "status": { "type": "string", "enum": ["Completed", "Pending", "Failed"] },
        "id": { "type": "string", "description": "External transaction ID" },
        "createdAt": { "type": "object" }
      },
      "required": ["uid", "amount", "method", "status"]
    }
  },
  "firestore": {
    "users": { "schema": "User", "description": "User profiles" },
    "services": { "schema": "Service", "description": "Available services" },
    "orders": { "schema": "Order", "description": "User orders" },
    "tickets": { "schema": "Ticket", "description": "Support tickets" },
    "transactions": { "schema": "Transaction", "description": "Financial records" }
  }
}
