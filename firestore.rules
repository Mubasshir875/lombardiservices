rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.uid == "AZf0mvKMByRJrNcF3VZIrd03ZBz1" ||
        request.auth.token.email == "shaikhmubasshir875@gmail.com" ||
        request.auth.token.email == "shaikhmubasshir76@gmail.com" ||
        request.auth.token.email == "lombardiraffaelo6@gmail.com"
      );
    }

    function isAdmin() {
      return isSuperAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Global Admin - Full access to everything
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // Users - Owner can read/write their own profile
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      allow read, write: if isAdmin();
    }

    // Services - Publicly readable, admin writable
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isSuperAdmin() || isAdmin();
    }

    // Orders - Owner can read/create
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Tickets - Owner can read/create
    match /tickets/{ticketId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Transactions - Owner can read/create
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Refills - Owner can read/create
    match /refills/{refillId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Subscriptions - Owner can read/create
    match /subscriptions/{subId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Updates - Publicly readable, admin writable
    match /updates/{updateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Test Connection
    match /test/connection {
      allow read: if true;
    }
  }
}
